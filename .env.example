# ── Henry v19™ Beast Bot — Environment Variables ──────────────────────────────

# Bot Identity
BOT_NAME=Henry v19™ Beast Bot
OWNER_NUMBER=254XXXXXXXXX
OWNER_NAME=Henry

# Pairing / Session
# Optional: pre-fill a number so the bot auto-pairs on startup (no web UI needed)
PAIRING_NUMBER=

# Server Ports
WEB_PORT=3000
PORT=5000

# Groq AI (for .ask command)
GROQ_API_KEY=your_groq_api_key_here

# Deployment URLs (auto-set by Railway/Render)
# RENDER_EXTERNAL_URL=https://your-bot.onrender.com
# RAILWAY_STATIC_URL=https://your-bot.up.railway.app
