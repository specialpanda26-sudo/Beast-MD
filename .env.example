# ── Henry v19™ Beast Bot — Environment Variables ──────────────────────────────

# Bot Identity
BOT_NAME=Henry v19™ Beast Bot
OWNER_NUMBER=254XXXXXXXXX
OWNER_NAME=Henry

# Pairing / Session
# Optional: pre-fill a number so the bot auto-pairs on startup (no web UI needed)
PAIRING_NUMBER=

# Server Ports
WEB_PORT=3000
PORT=5000

# Groq AI (for .ask command)
GROQ_API_KEY=your_groq_api_key_here

# Bot Panel Registration — OTP is sent via WhatsApp (the bot's own session),
# no setup needed. These SMTP vars are only for the OPTIONAL email fallback.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=youraccount@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_NAME=Henry Tech Bot Panel
REG_STARTER_CREDITS=80

# Deployment URLs (auto-set by Railway/Render)
# RENDER_EXTERNAL_URL=https://your-bot.onrender.com
# RAILWAY_STATIC_URL=https://your-bot.up.railway.app
