# Copy this to .env for local runs (Render/Railway: set these in the
# dashboard's Environment Variables section instead — render.yaml /
# railway.json already declare the keys, you just fill in the values).

# ── Core bot identity ────────────────────────────────────────────────────
OWNER_NUMBER=254712345678
OWNER_NAME=Your Name
BOT_NAME=Henry Ochibots v19™
CO_OWNERS=
SUB_ADMINS=
# Comma-separated name phrases the bot recognizes in GROUP chats (in
# addition to @mention/reply-to-bot) — word-boundary matched, so this is
# deliberately narrower than a bare "bot"/"henry" match (see the .menu
# entry for why). Defaults shown below if unset.
BOT_NAME_ALIASES=ochibots,henry ochibots,beast bot,beastbot

# ── Unattended startup (Railway/Render — no interactive terminal) ───────
# SESSION_ID: names this session so it auto-starts without the terminal
# prompt for a session name. PAIRING_NUMBER: if also set, auto-requests a
# pairing code for this number on boot instead of waiting for /pair.
# SESSION_ID=beastbot
# PAIRING_NUMBER=254712345678

# ── Security (set these yourself — there is NO default fallback) ────────
ADMIN_PASSWORD=changeme  # if forgotten, reset it via "Forgot password?" on /admin — the code is sent to OWNER_NUMBER above
BOT_LOGIN_USER=Henry     # username for .login and the hidden .menu unlock (defaults to "Henry" if unset)
BOT_LOGIN_PASS=changeme  # password for ".login [user] [pass]" AND the hidden ".menu [user] [pass]" owner unlock
OWNER_RECOVERY_SECRET=changeme

# ── Optional / cosmetic ───────────────────────────────────────────────────
PUBLIC_CONTACT_NUMBER=   # shown as the "Chat on WhatsApp" button on the public landing page. Leave blank to hide it.

# ── AI ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Ports ─────────────────────────────────────────────────────────────────
PORT=5000
WEB_PORT=3000

# ── Terminal pairing shortcut (optional) ─────────────────────────────────
# If set, the bot auto-requests a pairing code for this number on startup
# instead of waiting for someone to submit a number via /pair or chat.
# Leave blank to use the normal web/chat pairing flow.
# PAIRING_NUMBER=254712345678

# ── Persistent storage ───────────────────────────────────────────────────
# Where the SQLite DB, WhatsApp auth sessions, saved view-once media, and
# scheduled messages live. Locally this defaults fine to ./data. On Render,
# render.yaml already mounts a disk at /app/data and sets this for you. On
# Railway: add a Volume in the service settings, mount it at e.g. /app/data,
# then set this var to that same path — otherwise every redeploy wipes your
# WhatsApp session and you'll have to re-pair.
DATA_DIR=./data

# ── Email OTP (optional fallback delivery on /register) ─────────────────
# ⚠️ On Render, use RESEND_API_KEY below, NOT plain SMTP — Render blocks
# outbound SMTP ports (25/465/587) entirely, so SMTP_HOST/SMTP_PORT will
# never connect there no matter what you set them to. Resend sends the
# same email over HTTPS instead, which Render does allow.
#   1. https://resend.com/signup — free tier, 100 emails/day, no card.
#   2. Dashboard → API Keys → create one → paste below.
#   3. RESEND_FROM_EMAIL can stay as the default onboarding@resend.dev
#      until you verify your own domain in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Plain SMTP fallback — only works if your host doesn't block SMTP ports
# (e.g. Railway, your own VPS). Ignored automatically if RESEND_API_KEY is
# set above. Gmail: SMTP_PASSWORD must be a 16-character "App Password",
# NOT your normal Gmail password — Google Account → Security → 2-Step
# Verification (must be ON) → App passwords → generate one for "Mail".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_FROM_NAME=Henry Tech Bot Panel

# ── OTP delivery number (optional) ───────────────────────────────────────
# By default, OTPs are sent via WhatsApp from whichever number the bot
# itself is paired on — same chat history as the bot. There is no free
# anonymous "push notification" channel on WhatsApp (unlike Instagram/Meta,
# which owns dedicated verified sender numbers) — every message, including
# OTPs, must come from a real, paired WhatsApp account.
#
# If you want OTPs to come from a SEPARATE number than your main bot:
#   1. Get a second SIM/eSIM (or a paid virtual number from a provider that
#      actually supports WhatsApp registration — most free VOIP numbers
#      like TextNow/Google Voice get blocked by WhatsApp).
#   2. Visit /pair on this same deployment and pair that second number as
#      its own session (give it a distinct session name when prompted).
#   3. Put that session name here. The bot will use it specifically for
#      OTP messages while your main number keeps handling everything else.
OTP_SENDER_SESSION_ID=

# ── Wallet / M-Pesa top-ups (manual admin review, not auto-verified) ────
ADMIN_PAYTO_NUMBER=254712345678
REG_STARTER_CREDITS=80

# ── Referral program (auto-paid, no admin review) ────────────────────────
REFERRAL_REFERRER_BONUS=15
REFERRAL_REFERRED_BONUS=30

# ── Anti-ban (libs/baileys-antiban) ──────────────────────────────────────
# Everything below is optional. Rate limiting, warm-up, health monitoring,
# JID canonicalization, session-stability tracking, topology throttling,
# read-receipt jitter, device fingerprinting, and creds.json backups are
# ALWAYS ON already (no env vars needed) — the ones below are the
# externally-dependent extras that stay off until you configure them.
ANTIBAN_PRESET=moderate                # conservative | moderate | aggressive | high-volume
# ⚠️ KNOWN BUG WORKAROUND: leave this uncommented/false. The random-identity
# feature this disables currently overwrites the WA protocol `version` field
# with a mobile-app version number (wrong type of value) and the `browser`
# field with a phone-model string instead of a real desktop browser identity
# — WhatsApp rejects the connection outright (disconnect code 405) when this
# is on. Re-enable only once this is fixed upstream in baileys-antiban.
ANTIBAN_DEVICE_FINGERPRINT=false

# Owner is always exempt from every anti-ban block (no config needed). For
# everyone else, notify-only mode lets risky sends through instead of
# failing them, and DMs you a disclaimer instead. Default true. Set to
# false to restore hard-blocking for non-owner sends.
ANTIBAN_NOTIFY_ONLY=true

# Proxy rotation — requires real proxy IPs. Comma-separated URLs.
# socks5:// needs `npm install socks-proxy-agent`; http(s):// needs `npm install https-proxy-agent`.
# ANTIBAN_PROXY_LIST=socks5://user:pass@host1:1080,http://user:pass@host2:8080
# ANTIBAN_PROXY_STRATEGY=round-robin   # round-robin | random | least-recently-used | weighted

# Risk-change alerts — set any one of these to enable
# ANTIBAN_WEBHOOK_URL=https://your-endpoint.example.com/hook
# ANTIBAN_TELEGRAM_BOT_TOKEN=
# ANTIBAN_TELEGRAM_CHAT_ID=
# ANTIBAN_DISCORD_WEBHOOK_URL=
# ANTIBAN_WEBHOOK_MIN_RISK=medium      # low | medium | high | critical

# Smart broadcast scheduler — only affects .announce/admin bulk broadcasts,
# never normal command replies.
# ANTIBAN_SCHEDULER_ENABLED=true
# ANTIBAN_SCHEDULER_TZ=Africa/Nairobi
# ANTIBAN_SCHEDULER_START_HOUR=7
# ANTIBAN_SCHEDULER_END_HOUR=22

# ⚠️ DANGEROUS — only set this to "true" for a single deploy, then remove
# it. Wipes every session's saved antiban state (warm-up progress, health
# history, ban-recovery pause timers) on next boot. If WhatsApp is still
# actively enforcing a timelock/restriction on their end, clearing your
# local pause state and resuming sends early can turn a temporary
# restriction into a permanent ban. Only use this if you're confident
# enough real time has passed since the restriction, or you're consciously
# accepting that risk.
# RESET_ANTIBAN_STATE=true

# ── Media downloads (.dl / .download / .song / .audiomack / .videosearch) ──
# YouTube increasingly blocks cloud/datacenter IPs (Render, Railway, etc)
# with a "Sign in to confirm you're not a bot" challenge — this affects
# ANY yt-dlp-based bot hosted this way, not something specific to yours.
# The code already tries alternate YouTube API clients automatically as a
# first line of defense (no setup needed). If it's still unreliable,
# export cookies.txt from a real logged-in YouTube account in your
# browser (e.g. the "Get cookies.txt" extension) and point this at it —
# most reliable fix, but cookies expire and need periodic refreshing.
# YTDLP_COOKIES_FILE=/opt/render/project/src/cookies.txt

